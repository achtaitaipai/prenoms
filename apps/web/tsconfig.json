{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@prenoms/server": ["../../apps/server/src/index.ts"],
      "@prenoms/ui/*": ["../../packages/ui/src/*"],
      "styled-system/*": ["../../packages/ui/styled-system/*"]
    }
  }
}
